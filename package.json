{
  "name": "saamagrii",
  "version": "1.0.0",
  "description": "WhatsApp-native AI assistant for kirana shop owners — inventory, udhaar, billing, and supplier tracking.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "engines": {
    "node": ">=18.x",
    "npm": ">=8.x"
  },
  "dependencies": {
    "express": "^4.18.2",
    "twilio": "^4.23.0",
    "axios": "^1.6.7",
    "node-cron": "^3.0.3",
    "dotenv": "^16.3.1",
    "pdfkit": "^0.14.0",
    "moment": "^2.29.4",
    "airtable": "^0.12.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "@soniox/soniox-node": "^1.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/tests/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": ["./tests/setup.js"]
  },
  "eslintConfig": {
    "extends": ["standard"],
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "nodemonConfig": {
    "watch": ["server.js", "api/", "database.js", "dailySummary.js"],
    "ignore": ["node_modules/", "coverage/", "tests/"],
    "ext": "js",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
